# ── Database ──
DATABASE_URL=postgres://user:pass@alwaysdata-host:5432/sex-worker-safety

# ── Auth ──
JWT_SECRET=replace-with-a-strong-64-char-secret
JWT_EXPIRY_HOURS=24

# ── API Gateway ──
GATEWAY_PORT=8080
GATEWAY_UPSTREAM_ATTESTATION=http://attestation:3001
GATEWAY_UPSTREAM_CHECKIN=http://checkin-dao:3002
GATEWAY_UPSTREAM_ANALYTICS=http://analytics:3003

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60

# ── Attestation Service ──
ATTESTATION_PORT=3001
ATTESTATION_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# ── Check-in & Emergency ──
CHECKIN_PORT=3002
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
EMERGENCY_WEBHOOK_URL=

# ── Analytics ──
ANALYTICS_PORT=3003

# ── Qdrant ──
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── TLS / ACME ──
ACME_DOMAIN=
ACME_EMAIL=
